{
  "manifest_version": 3,
  "name": "QueueTube",
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "queuetube@issac.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "description": "Transforms YouTube into a single-player experience with a persistent queue.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://www.youtube.com/oembed*",
    "https://noembed.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background/index.js"],
    "service_worker": "background/index.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/style.css"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "gather-tabs": {
      "suggested_key": {
        "default": "Alt+Shift+Q"
      },
      "description": "Gather all open YouTube tabs into QueueTube"
    },
    "next-video": {
      "suggested_key": {
        "default": "Alt+Shift+N"
      },
      "description": "Play next video in queue"
    },
    "previous-video": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Play previous video in queue"
    },
    "toggle-queue": {
      "suggested_key": {
        "default": "Alt+Shift+L"
      },
      "description": "Toggle Queue Sidebar"
    }
  }
}
